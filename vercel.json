{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": true,
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/programisci-graficy/", "destination": "/programisci" },
    { "source": "/e-commerce/", "destination": "/ecommerce" },
    { "source": "/tlumacze-lektorzy/", "destination": "/tlumacze" },
    { "source": "/zespol-fundacji-firma-dla-kazdego/", "destination": "/o-nas" },
    { "source": "/:path*/assets/:file*", "destination": "/assets/:file*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
