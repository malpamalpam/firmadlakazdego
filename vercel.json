{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/uk/programisci", "destination": "/programisci.html" },
    { "source": "/uk/ecommerce", "destination": "/ecommerce.html" },
    { "source": "/uk/architekci", "destination": "/architekci.html" },
    { "source": "/uk/tlumacze", "destination": "/tlumacze.html" },
    { "source": "/uk/muzycy", "destination": "/muzycy.html" },
    { "source": "/uk/inne-branze", "destination": "/inne-branze.html" },
    { "source": "/uk/dla-pracodawcow", "destination": "/dla-pracodawcow.html" },
    { "source": "/uk/cudzoziemcy", "destination": "/cudzoziemcy.html" },
    { "source": "/uk/o-nas", "destination": "/o-nas.html" },
    { "source": "/uk/faq", "destination": "/faq.html" },
    { "source": "/uk/kontakt", "destination": "/kontakt.html" },
    { "source": "/uk/regulamin", "destination": "/regulamin.html" },
    { "source": "/uk/jak-dzialamy", "destination": "/jak-dzialamy.html" },
    { "source": "/uk/blog", "destination": "/blog.html" },
    { "source": "/uk/inkubator-przedsiebiorczosci", "destination": "/inkubator-przedsiebiorczosci.html" },
    { "source": "/uk/inne-uslugi", "destination": "/inne-uslugi.html" },
    { "source": "/en/programisci", "destination": "/programisci.html" },
    { "source": "/en/ecommerce", "destination": "/ecommerce.html" },
    { "source": "/en/architekci", "destination": "/architekci.html" },
    { "source": "/en/tlumacze", "destination": "/tlumacze.html" },
    { "source": "/en/muzycy", "destination": "/muzycy.html" },
    { "source": "/en/inne-branze", "destination": "/inne-branze.html" },
    { "source": "/en/dla-pracodawcow", "destination": "/dla-pracodawcow.html" },
    { "source": "/en/cudzoziemcy", "destination": "/cudzoziemcy.html" },
    { "source": "/en/o-nas", "destination": "/o-nas.html" },
    { "source": "/en/faq", "destination": "/faq.html" },
    { "source": "/en/kontakt", "destination": "/kontakt.html" },
    { "source": "/en/regulamin", "destination": "/regulamin.html" },
    { "source": "/en/jak-dzialamy", "destination": "/jak-dzialamy.html" },
    { "source": "/en/blog", "destination": "/blog.html" },
    { "source": "/en/inkubator-przedsiebiorczosci", "destination": "/inkubator-przedsiebiorczosci.html" },
    { "source": "/en/inne-uslugi", "destination": "/inne-uslugi.html" },
    { "source": "/ru/programisci", "destination": "/programisci.html" },
    { "source": "/ru/ecommerce", "destination": "/ecommerce.html" },
    { "source": "/ru/architekci", "destination": "/architekci.html" },
    { "source": "/ru/tlumacze", "destination": "/tlumacze.html" },
    { "source": "/ru/muzycy", "destination": "/muzycy.html" },
    { "source": "/ru/inne-branze", "destination": "/inne-branze.html" },
    { "source": "/ru/dla-pracodawcow", "destination": "/dla-pracodawcow.html" },
    { "source": "/ru/cudzoziemcy", "destination": "/cudzoziemcy.html" },
    { "source": "/ru/o-nas", "destination": "/o-nas.html" },
    { "source": "/ru/faq", "destination": "/faq.html" },
    { "source": "/ru/kontakt", "destination": "/kontakt.html" },
    { "source": "/ru/regulamin", "destination": "/regulamin.html" },
    { "source": "/ru/jak-dzialamy", "destination": "/jak-dzialamy.html" },
    { "source": "/ru/blog", "destination": "/blog.html" },
    { "source": "/ru/inkubator-przedsiebiorczosci", "destination": "/inkubator-przedsiebiorczosci.html" },
    { "source": "/ru/inne-uslugi", "destination": "/inne-uslugi.html" },
    { "source": "/uk/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/en/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/ru/assets/:path*", "destination": "/assets/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
